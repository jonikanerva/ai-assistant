{
  "name": "bob",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Finnish-speaking home voice assistant on the OpenAI Realtime API. See VISION.md and STACK.md.",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "test": "vitest run --passWithNoTests",
    "token": "node --env-file=.env server/token.ts",
    "verify": "pnpm run typecheck && biome ci . && pnpm run test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@openai/agents": "^0.11.7"
  }
}

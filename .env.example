# Copy to `.env` and fill in. `.env` is gitignored.
#
# Used ONLY by the local token process to mint short-lived ephemeral client
# secrets (POST /v1/realtime/client_secrets). It is NEVER sent to the browser
# and NEVER committed. The browser connects with the returned `ek_...` token.
# See STACK.md → "Connection / security".
OPENAI_API_KEY=sk-proj-...
